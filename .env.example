# ============================================================
# PrintMe — Environment variables (copy to .env and fill in)
# ============================================================

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@localhost:5432/printme?schema=public"

# --- OpenAI ---
OPENAI_API_KEY="sk-..."
# When unset/empty the app runs AI in MOCK mode (returns placeholder images).
OPENAI_IMAGE_MODEL="gpt-image-1"

# --- Cloudflare R2 (S3-compatible) ---
# When unset/empty uploads run in MOCK mode (return data URLs / placeholders).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="printme"
R2_PUBLIC_URL="https://<your-bucket>.r2.dev"

# --- Telegram (manager order notifications) ---
# When unset/empty notifications are logged to console instead of sent.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_MANAGER_CHAT_ID=""

# --- Admin auth (simple credential gate for /admin) ---
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"
ADMIN_SESSION_SECRET="generate-a-long-random-string"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ru"
